# =========================================
# Production Environment Variables
# Copy this file to .env and update values
# =========================================

# MySQL Database URL
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE
# For Docker: mysql+pymysql://faceapp:faceapp123@mysql:3306/face_attendance
# For Local MySQL: mysql+pymysql://faceapp:faceapp123@localhost:3306/face_attendance
# For Server: mysql+pymysql://faceapp:faceapp123@your-server-ip:3306/face_attendance
DATABASE_URL=mysql+pymysql://faceapp:faceapp123@localhost:3306/face_attendance

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate strong key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production

# Server Settings
HOST=0.0.0.0
PORT=8000
